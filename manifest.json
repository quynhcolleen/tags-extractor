{
  "manifest_version": 3,
  "name": "Booru Tag Extractor",
  "version": "1.0",
  "description": "Extract tags from rule34, danbooru and gelbooru",
  "permissions": ["scripting", "activeTab", "clipboardWrite"],
  "host_permissions": [
    "*://rule34.xxx/*",
    "*://danbooru.donmai.us/*",
    "*://gelbooru.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Booru Tag Extractor",
    "default_icon": {
      "16": "logo16.png",
      "32": "logo32.png",
      "48": "logo48.png"
    }
  },
  "icons": {
    "16": "logo16.png",
    "32": "logo32.png",
    "48": "logo48.png"
  }
}
